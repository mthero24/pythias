{
  "name": "pythias-storefront-mobile",
  "version": "0.1.0",
  "private": true,
  "description": "White-label native mobile shopping app for Pythias storefronts (Expo). One codebase, configured per store via EXPO_PUBLIC_* env at build time. NOT part of the web monorepo workspaces — has its own deps.",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "expo": "~51.0.0",
    "expo-constants": "~16.0.0",
    "expo-status-bar": "~1.12.0",
    "expo-notifications": "~0.28.19",
    "expo-device": "~6.0.2",
    "react": "18.2.0",
    "react-native": "0.74.5",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "react-native-screens": "~3.31.1",
    "react-native-safe-area-context": "4.10.5",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@stripe/stripe-react-native": "0.38.6"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0"
  }
}
