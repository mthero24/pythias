# ─────────────────────────────────────────────────────────────────────────────
# Pythias Storefront — environment template (copy to .env.local, fill in, restart)
# This is the BUYER-FACING multi-tenant storefront app (one app serves all stores by host).
# See docs/go-live.md for the full launch runbook.
# ─────────────────────────────────────────────────────────────────────────────

# ── Core ─────────────────────────────────────────────────────────────────────
PORT=3020
# Database — points at the shared platform DB (same cluster the platform/premier use).
PLATFORM_MONGO_URL=
# Base domain for store subdomains + public feed/links → brand.pythias.store
STOREFRONT_BASE_DOMAIN=pythias.store
# Optional: force a store in local dev (skip host resolution)
# DEV_SITE_SLUG=

# ── Stripe — MARKETPLACE account (buyer payments, Connect payouts, Stripe Tax) ─
# ⚠️ This is the SEPARATE marketplace Stripe account — NOT the platform billing account.
# Use sk_test_/pk_test_ in staging, live keys in prod.
STOREFRONT_STRIPE_SECRET=
STOREFRONT_STRIPE_PUBLISHABLE=
# Webhook signing secret for /api/checkout/webhook (events: payment_intent.succeeded,
# charge.dispute.created, charge.dispute.closed).
STOREFRONT_STRIPE_WEBHOOK_SECRET=

# ── Email (Resend) + SMS (Twilio) — marketing + transactional outbox ──────────
RESEND_API_KEY=
STOREFRONT_EMAIL_FROM=Your Store <hello@yourstore.com>
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# or a Messaging Service instead of a single from-number:
# TWILIO_MESSAGING_SERVICE_SID=
# Outbox drain batch size (batch × cron interval = send rate; keep low to warm reputation).
OUTBOX_BATCH=30

# ── Review photo uploads (Wasabi/S3) — server-side only ──────────────────────
WASABI_ACCESS_KEY=
WASABI_SECRET_KEY=
STOREFRONT_UPLOAD_BUCKET=
WASABI_ENDPOINT=
WASABI_REGION=
WASABI_PUBLIC_BASE=

# ── Merchant of Record ───────────────────────────────────────────────────────
# Legal entity shown on the checkout disclosure ("Merchant of Record: …") + statement note.
# Must keep the NEXT_PUBLIC_ prefix (read in the buyer-facing checkout). Match your Stripe
# statement descriptor. Defaults to "Pythias Technologies LLC" if unset.
NEXT_PUBLIC_MOR_ENTITY=Pythias Technologies LLC

# ── AI (buyer concierge, AI campaigns/listings, autopilot) ───────────────────
ANTHROPIC_API_KEY=

# ── Internal (server-to-server: routing handoff + cron endpoints) ────────────
# Shared secret guarding the internal endpoints (must match the platform's value).
PYTHIAS_INTERNAL_KEY=
# Where the storefront calls the platform routing engine (server-to-server).
PLATFORM_INTERNAL_BASE=http://127.0.0.1:3010
# Signs buyer JWTs / unsubscribe tokens.
STOREFRONT_JWT_SECRET=
