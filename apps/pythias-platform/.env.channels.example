# ─────────────────────────────────────────────────────────────────────────────
# Channel Syndication — environment template
# Copy the lines you need into apps/pythias-platform/.env.local (and premier's env if
# sellers connect channels there too), fill in values, then `pm2 reload`.
# Leave a channel's vars blank/absent → that channel just shows "Setup required by Pythias".
# Full setup steps + sandbox notes: docs/channel-syndication-setup.md
# ─────────────────────────────────────────────────────────────────────────────

# ── Shared (needed for channels to work at all) ──────────────────────────────
# Used to sign OAuth state + (fallback) encrypt stored tokens. Usually already set for next-auth.
NEXTAUTH_SECRET=
# Encrypts channel OAuth tokens at rest (AES-256-GCM). Any 32+ char secret. Don't change after
# tokens are stored (existing tokens become undecryptable → sellers must reconnect).
CHANNEL_TOKEN_KEY=
# Builds the public feed URL + product links when a store has no custom domain.
STOREFRONT_BASE_DOMAIN=pythias.store
# Shared secret for the internal cron endpoints (ad-spend sync, etc.). Usually already set.
PYTHIAS_INTERNAL_KEY=

# ── Google Merchant Center (product push) ────────────────────────────────────
# Google Cloud Console → enable "Content API for Shopping" → OAuth client (Web).
# Redirect URI: https://<platform-domain>/api/storefront/channels/google/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ── Google Ads (auto ad-spend → ROI) ─────────────────────────────────────────
# Google Ads → API Center. The broadened Google OAuth scope already covers Ads; sellers connected
# before ad-spend existed must reconnect.
GOOGLE_ADS_DEVELOPER_TOKEN=
# Only if your tokens are issued under a manager (MCC) account:
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# ── Microsoft / Bing Merchant Center (product push + ad spend) ───────────────
# ads.microsoft.com + an app registered in Azure/Entra (multitenant).
# Redirect URI: https://<platform-domain>/api/storefront/channels/microsoft/callback
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=
MICROSOFT_ADS_DEVELOPER_TOKEN=
# Platform-level Bing customer (manager) id — needed for the ad-spend Reporting API.
MICROSOFT_ADS_CUSTOMER_ID=
# ── Microsoft SANDBOX overrides (uncomment to validate against the sandbox) ──
# Sandbox accounts: https://signupsandbox.bingads.microsoft.com — universal dev token BBD37VB98
# MICROSOFT_AUTH_URL=https://login.windows-ppe.net/consumers/oauth2/v2.0/authorize
# MICROSOFT_TOKEN_URL=https://login.windows-ppe.net/consumers/oauth2/v2.0/token
# MICROSOFT_CONTENT_BASE=https://content.api.sandbox.bingads.microsoft.com
# MICROSOFT_REPORTING_URL=https://reporting.api.sandbox.bingads.microsoft.com/Api/Advertiser/Reporting/v13/ReportingService.svc
# MICROSOFT_ADS_DEVELOPER_TOKEN=BBD37VB98

# ── Meta (Facebook & Instagram) — product push + ad spend ────────────────────
# developers.facebook.com → Business app → Marketing/Commerce. Scopes need App Review to go live:
# catalog_management, business_management, ads_read.
# Redirect URI: https://<platform-domain>/api/storefront/channels/meta/callback
META_OAUTH_CLIENT_ID=
META_OAUTH_CLIENT_SECRET=

# ── Pinterest (product push) ─────────────────────────────────────────────────
# developers.pinterest.com → enable Catalogs (catalogs:read, catalogs:write). Starts in trial access.
# Redirect URI: https://<platform-domain>/api/storefront/channels/pinterest/callback
PINTEREST_OAUTH_CLIENT_ID=
PINTEREST_OAUTH_CLIENT_SECRET=

# ── TikTok (product push via feed-URL catalog) ───────────────────────────────
# business-api.tiktok.com → app + Business Center.
# Redirect URI: https://<platform-domain>/api/storefront/channels/tiktok/callback
TIKTOK_APP_ID=
TIKTOK_APP_SECRET=
# Your TikTok Business Center id (platform-level for now).
TIKTOK_BC_ID=

# ── Snapchat (product push) ──────────────────────────────────────────────────
# business.snapchat.com → Business Manager → OAuth app (scope snapchat-marketing-api).
# Redirect URI: https://<platform-domain>/api/storefront/channels/snapchat/callback
SNAPCHAT_OAUTH_CLIENT_ID=
SNAPCHAT_OAUTH_CLIENT_SECRET=

# ── X (Twitter) — Ads Catalog API (OAuth 1.0a) ───────────────────────────────
# developer.x.com → app with Ads API access (early-access). Use the app's API Key/Secret.
# Enable OAuth 1.0a + set the callback: https://<platform-domain>/api/storefront/channels/x/callback
X_CONSUMER_KEY=
X_CONSUMER_SECRET=

# ── Reddit — feed-based, NO credentials needed ───────────────────────────────
# Add the universal feed URL (shown on the Sales Channels page) in Reddit Ads → Catalogs.
